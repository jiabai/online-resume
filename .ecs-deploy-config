# ============================================================
# 阿里云 ECS 部署配置文件
# ============================================================

# 必填：SSH 连接信息 (格式: user@ip 或 user@ip:port)
SERVER=root@

# 可选：绑定的域名 (配置后会显示在部署完成提示中)
DOMAIN=

# 远程站点目录 (默认 /var/www/resume，一般无需修改)
REMOTE_DIR=/var/www/resume
